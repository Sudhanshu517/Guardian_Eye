# MongoDB Configuration
MONGODB_URL=
DATABASE_NAME=guardianeye

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# CORS Configuration (for frontend)
FRONTEND_URL=http://localhost:3000

# Alert Services (Mock for demo)
TWILIO_ACCOUNT_SID=mock_sid
TWILIO_AUTH_TOKEN=mock_token
TWILIO_PHONE_NUMBER=+1234567890

# File Upload
MAX_FILE_SIZE=10485760
EVIDENCE_DIR=./evidence

# AI Model Service Configuration
# Change this to your model API URL
MODEL_API_URL=http://localhost:8001
# For Colab with ngrok: MODEL_API_URL=https://xxxx-xx-xxx-xxx-xxx.ngrok-free.app
# For Hugging Face Space: MODEL_API_URL=https://your-space.hf.space
MODEL_TIMEOUT=30
